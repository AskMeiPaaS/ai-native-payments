# =========================================================
# 🚀 AI-NATIVE PAYMENTS: Environment Template
# =========================================================
# Copy this file to .env and fill in your actual values.
# This template is safe to commit to version control.
# 
# SECURITY: Never commit .env with actual secrets!
# =========================================================

# =========================================================
# 🌐 CORE APPLICATION SETTINGS
# =========================================================
APP_PORT=8080
SPRING_THREADS_VIRTUAL_ENABLED=true

# =========================================================
# 🗄️ MONGODB DUAL-DATABASE CONFIGURATION
# =========================================================
# SECURITY: Set strong passwords for MongoDB credentials in production
# Format: mongodb://username:password@host:port/database?authSource=admin
PRIMARY_MONGO_URI=mongodb://<user>:<password>@mongodb-atlas:27017/pass_main?authSource=admin
PRIMARY_DB_NAME=pass_main

AUDIT_MONGO_URI=mongodb://<user>:<password>@mongodb-atlas:27017/pass_audit?authSource=admin
AUDIT_DB_NAME=pass_audit

HITL_MONGO_URI=mongodb://<user>:<password>@mongodb-atlas:27017/pass_hitl?authSource=admin
HITL_DB_NAME=pass_hitl
MEMORY_MONGO_URI=mongodb://<user>:<password>@mongodb-atlas:27017/pass_memory?authSource=admin
MEMORY_DB_NAME=pass_memory

SPRING_DATA_TRANSACTION_MANAGER=true

# =========================================================
# 🧠 AI ORCHESTRATION: EMBEDDING MODEL
# =========================================================
# Get your key from https://dash.voyageai.com
VOYAGE_API_KEY=your_voyage_api_key_here
EMBEDDING_BASE_URL=http://embedding-service:8000
EMBEDDING_API_KEY=none
EMBEDDING_MODEL_NAME=voyage-4-nano

# =========================================================
# 🔄 AI ORCHESTRATION: RERANKER
# =========================================================
# Reranker is served by dedicated TEI container (bge-reranker-v2-m3)
RERANKER_BASE_URL=http://reranker-service:8000
RERANKER_MODEL_NAME=bge-reranker-v2-m3
RERANKER_TOP_K=5

# =========================================================
# 🤖 AI ORCHESTRATION: LLM
# =========================================================
LLM_BASE_URL=http://ollama:11434
LLM_MODEL_NAME=llama2
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=300

# =========================================================
# 🌐 HTTP CLIENT CONFIGURATION
# =========================================================
HTTP_CONNECT_TIMEOUT=10
HTTP_REQUEST_TIMEOUT=300

# =========================================================
# 🔐 AI-NATIVE LIMITS & THRESHOLDS
# =========================================================
AUTO_EXECUTE_THRESHOLD=0.95

# =========================================================
# 📚 MONGODB COLLECTIONS & INDEXES
# =========================================================
COLLECTION_PROFILES=user_profiles
COLLECTION_TRANSACTIONS=transactions
COLLECTION_AUDIT=system_audit_logs
VECTOR_INDEX_NAME=behavioral_vector_index

# =========================================================
# 📋 LOGGING CONFIGURATION
# =========================================================
LOGGING_LEVEL_APP=DEBUG
LOGGING_LEVEL_LANGCHAIN4J=DEBUG
LOGGING_LEVEL_MONGODB=INFO

# =========================================================
# � SECURITY: CORS & AUTHENTICATION
# =========================================================
# Restrict CORS to your frontend domain(s)
# Development: http://localhost:3000
# Production: https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# =========================================================
# 🐳 DOCKER COMPOSE SERVICES
# =========================================================
# SECURITY: Change these passwords in production!
# Use strong, randomly generated passwords for production environments
MONGODB_INITDB_ROOT_USERNAME=admin
# SECURITY: Use a strong randomly generated password
MONGODB_INITDB_ROOT_PASSWORD=<strong-random-password>
OLLAMA_HOST=0.0.0.0:11434
