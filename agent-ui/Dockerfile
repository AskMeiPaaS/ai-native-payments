# Stage 1: Install dependencies
FROM node:22-bookworm AS deps
WORKDIR /app
# Use Debian security updates instead of Alpine for better patch coverage
RUN apt-get update && apt-get upgrade -y && apt-get clean && rm -rf /var/lib/apt/lists/*
COPY package.json package-lock.json ./
RUN npm ci

# Stage 2: Build the Generative UI
FROM node:22-bookworm AS builder
WORKDIR /app
RUN apt-get update && apt-get upgrade -y && apt-get clean && rm -rf /var/lib/apt/lists/*
# Accept the backend URL at build time so next.config.ts rewrites() bakes in the correct host
ARG JAVA_BACKEND_URL=http://localhost:8080
ENV JAVA_BACKEND_URL=${JAVA_BACKEND_URL}
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

# Stage 3: Production Runner - Using distroless for minimal attack surface
FROM node:22-bookworm-slim AS runner
WORKDIR /app
RUN apt-get update && apt-get upgrade -y && apt-get clean && rm -rf /var/lib/apt/lists/*
ENV NODE_ENV=production
ENV PORT=3000
ENV JAVA_BACKEND_URL=http://api-gateway:8080
RUN useradd -m -u 1001 appuser

# Copy the standalone output generated by Next.js
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

# Copy entrypoint script to ensure environment variables are passed to Node.js
COPY docker-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh && chown appuser:appuser /entrypoint.sh

# Run as non-root user
USER appuser

EXPOSE 3000

# Use entrypoint to ensure environment variables are available to Node.js
ENTRYPOINT ["/entrypoint.sh"]